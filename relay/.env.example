# relay server
RELAY_HOST=0.0.0.0
RELAY_PORT=8787
RELAY_EVENT_PATH=/agent-view/events
RELAY_QQ_CALLBACK_PATH=/qq/callback
RELAY_MANUAL_REPLY_PATH=/debug/reply

# agent-view -> relay auth (must match webhookTokenEnv in agent-view config)
AV_NOTIFY_TOKEN=replace_me

# optional: protect QQ callback endpoint if you front QQ events via your gateway
RELAY_CALLBACK_TOKEN=
RELAY_LOCAL_CALLBACK_URL=http://127.0.0.1:8787/qq/callback

# relay -> agent-view action endpoint
AGENT_VIEW_ACTION_URL=http://127.0.0.1:5177/notify/action
AV_NOTIFY_ACTION_SECRET=replace_me
ACTION_TIMEOUT_MS=5000
CODE_TTL_SECONDS=300

# QQ official bot credentials
QQ_APP_ID=replace_with_app_id
QQ_APP_SECRET=replace_with_app_secret

# QQ OpenAPI endpoints
QQ_API_BASE=https://api.sgroup.qq.com
QQ_TOKEN_URL=https://bots.qq.com/app/getAppAccessToken
DISCOVERED_OPENID_FILE=./discovered-openids.log

# targets (comma-separated; can set one or both)
QQ_TARGET_USER_OPENID=
QQ_TARGET_GROUP_OPENID=
